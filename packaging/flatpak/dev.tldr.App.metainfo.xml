<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>dev.tldr.App</id>
  <name>TLDR</name>
  <summary>AI-powered Mattermost chat summariser</summary>
  <description>
    <p>
      TLDR reads your unread Mattermost channels and produces concise summaries
      using a language model. It tracks action items across sessions, highlights
      channels where you were mentioned, and serves a local web UI for reviewing
      summaries at a glance.
    </p>
  </description>
  <url type="homepage">https://github.com/infinitedevice/tldr</url>
  <url type="bugtracker">https://github.com/infinitedevice/tldr/issues</url>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT OR Apache-2.0</project_license>
  <launchable type="desktop-id">dev.tldr.App.desktop</launchable>
  <provides>
    <binary>tldr-daemon</binary>
    <binary>tldr</binary>
  </provides>
  <releases>
    <release version="0.1.0" date="2025-01-01">
      <description><p>Initial release.</p></description>
    </release>
  </releases>
  <content_rating type="oars-1.1" />
</component>
